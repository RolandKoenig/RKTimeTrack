{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging.HttpLoggingMiddleware": "Information"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "ViteDevelopmentServer": {
    "Port": 5001,
    "RoutesForAspNet": [
      "/api",
      "/swagger"
    ]
  },
  "FileBasedTimeTrackingRepository": {
    "WriteIndentedJson": true,
    "PersistenceFileDataStore": {
      "Type": "FileSystem",
      "FileSystemRootPath": "../../testdata/runtimedata/"
    }
  },
  "StaticTopicRepository": {
    "SourceFilePath": "topics.json",
    "FileDataStore": {
      "Type": "FileSystem",
      "FileSystemRootPath": "../../testdata/masterdata/"
    }
  },
  "ExportAdapter": {
    "ExportFileDataStore": {
      "Type": "FileSystem",
      "FileSystemRootPath": "../../testdata/export/"
    }
  }
}
